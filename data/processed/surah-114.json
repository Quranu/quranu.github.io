{
  "surahNumber": 114,
  "name": {
    "ar": "سورة الـناس",
    "bm": "Manusia",
    "en": "People"
  },
  "totalAyahs": 6,
  "ayahs": [
    {
      "number": 0,
      "arabic": "بِسْمِ اللَّهِ الرَّحْمَٰنِ الرَّحِيمِ",
      "bm": "Dengan Nama Allah yang Maha Pengasih lagi Maha Penyayang.",
      "en": "In the name of God, Most Gracious, Most Merciful",
      "audio": "https://everyayah.com/data/Alafasy_64kbps/114000.mp3"
    },
    {
      "number": 1,
      "arabic": "قُل أَعوذُ بِرَبِّ النّاسِ",
      "bm": "Katakanlah, \" Aku mencari perlindungan Tuhan kepada manusia.",
      "en": "Say, \"I seek refuge in the Lord of the people.",
      "audio": "https://everyayah.com/data/Alafasy_64kbps/114001.mp3"
    },
    {
      "number": 2,
      "arabic": "مَلِكِ النَّاسِ",
      "bm": "\"Raja kepada manusia.",
      "en": "\"The King of the people.",
      "audio": "https://everyayah.com/data/Alafasy_64kbps/114002.mp3"
    },
    {
      "number": 3,
      "arabic": "إِلَٰهِ النَّاسِ",
      "bm": "\"Tuhan kepada manusia.",
      "en": "\"The god of the people.",
      "audio": "https://everyayah.com/data/Alafasy_64kbps/114003.mp3"
    },
    {
      "number": 4,
      "arabic": "مِنْ شَرِّ الْوَسْوَاسِ الْخَنَّاسِ",
      "bm": "\"Dari kejahatan yang menghasuti pembisik pembisik.",
      "en": "\"From the evils of sneaky whisperers.",
      "audio": "https://everyayah.com/data/Alafasy_64kbps/114004.mp3"
    },
    {
      "number": 5,
      "arabic": "الَّذِي يُوَسْوِسُ فِي صُدُورِ النَّاسِ",
      "bm": "\"Yang membisik didalam dada dada manusia.",
      "en": "\"Who whisper into the chests of the people.",
      "audio": "https://everyayah.com/data/Alafasy_64kbps/114005.mp3"
    },
    {
      "number": 6,
      "arabic": "مِنَ الْجِنَّةِ وَالنَّاسِ",
      "bm": "\"Biarpun mereka itu dari para jin, ataupun manusia.\"",
      "en": "\"Be they of the jinns, or the people.\"",
      "audio": "https://everyayah.com/data/Alafasy_64kbps/114006.mp3"
    }
  ]
}