{
  "surahNumber": 104,
  "name": {
    "ar": "سورة الهمزة",
    "bm": "Pengumpat",
    "en": "The Backbiter"
  },
  "totalAyahs": 9,
  "ayahs": [
    {
      "number": 0,
      "arabic": "بِسْمِ اللَّهِ الرَّحْمَٰنِ الرَّحِيمِ",
      "bm": "Dengan Nama Allah yang Maha Pengasih lagi Maha Penyayang.",
      "en": "In the name of God, Most Gracious, Most Merciful",
      "audio": "https://everyayah.com/data/Alafasy_64kbps/104000.mp3"
    },
    {
      "number": 1,
      "arabic": "وَيلٌ لِكُلِّ هُمَزَةٍ لُمَزَةٍ",
      "bm": "Malang sungguh setiap pengumpat, pemitnah.",
      "en": "Woe to every backbiter, slanderer.",
      "audio": "https://everyayah.com/data/Alafasy_64kbps/104001.mp3"
    },
    {
      "number": 2,
      "arabic": "الَّذِي جَمَعَ مَالًا وَعَدَّدَهُ",
      "bm": "Dia menyorokkan wangnya dan mengiranya.",
      "en": "He hoards money and counts it.",
      "audio": "https://everyayah.com/data/Alafasy_64kbps/104002.mp3"
    },
    {
      "number": 3,
      "arabic": "يَحْسَبُ أَنَّ مَالَهُ أَخْلَدَهُ",
      "bm": "Seolah olah wangnya akan membuatnya hidup selama lamanya.",
      "en": "As if his money will make him immortal.",
      "audio": "https://everyayah.com/data/Alafasy_64kbps/104003.mp3"
    },
    {
      "number": 4,
      "arabic": "كَلَّا لَيُنْبَذَنَّ فِي الْحُطَمَةِ",
      "bm": "Tidak sekali; dia akan dicampakkan kedalam Pemusnah.",
      "en": "Never; he will be thrown into the Devastator.",
      "audio": "https://everyayah.com/data/Alafasy_64kbps/104004.mp3"
    },
    {
      "number": 5,
      "arabic": "وَمَا أَدْرَٮکَ مَا الْحُطَمَةُ",
      "bm": "Tahukah kamu apakah Pemusnah itu?",
      "en": "Do you know what the Devastator is?",
      "audio": "https://everyayah.com/data/Alafasy_64kbps/104005.mp3"
    },
    {
      "number": 6,
      "arabic": "نَارُ اللَّهِ الْمُوقَدَةُ",
      "bm": "Nyalaan api Neraka dari Allah.",
      "en": "GOD's blazing Hellfire.",
      "audio": "https://everyayah.com/data/Alafasy_64kbps/104006.mp3"
    },
    {
      "number": 7,
      "arabic": "الَّتِي تَطَّلِعُ عَلَى الْأَفْئِدَةِ",
      "bm": "Ianya membakarkan mereka dari dalam dan luar.",
      "en": "It burns them inside out.",
      "audio": "https://everyayah.com/data/Alafasy_64kbps/104007.mp3"
    },
    {
      "number": 8,
      "arabic": "إِنَّهَا عَلَيْهِمْ مُؤْصَدَةٌ",
      "bm": "Mereka akan dikurungkan didalamnya.",
      "en": "They will be confined therein.",
      "audio": "https://everyayah.com/data/Alafasy_64kbps/104008.mp3"
    },
    {
      "number": 9,
      "arabic": "فِي عَمَدٍ مُمَدَّدَةٍ",
      "bm": "Didalam tiang tiang lurus yang diperpanjangkan.",
      "en": "In extended columns.",
      "audio": "https://everyayah.com/data/Alafasy_64kbps/104009.mp3"
    }
  ]
}