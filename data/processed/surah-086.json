{
  "surahNumber": 86,
  "name": {
    "ar": "سورة الـطارق",
    "bm": "Bintang Yang Terang",
    "en": "The Bright Star"
  },
  "totalAyahs": 17,
  "ayahs": [
    {
      "number": 0,
      "arabic": "بِسْمِ اللَّهِ الرَّحْمَٰنِ الرَّحِيمِ",
      "bm": "Dengan Nama Allah yang Maha Pengasih lagi Maha Penyayang.",
      "en": "In the name of God, Most Gracious, Most Merciful",
      "audio": "https://everyayah.com/data/Alafasy_64kbps/086000.mp3"
    },
    {
      "number": 1,
      "arabic": "وَالسَّماءِ وَالطّارِقِ",
      "bm": "Demi langit dan Al-Taareq.",
      "en": "By the sky and Al-Taareq.",
      "audio": "https://everyayah.com/data/Alafasy_64kbps/086001.mp3"
    },
    {
      "number": 2,
      "arabic": "وَمَا أَدْرَٮکَ مَا الطَّارِقُ",
      "bm": "Tahukah kamu apa itu Al-Taareq?",
      "en": "Do you know what Al-Taareq is?",
      "audio": "https://everyayah.com/data/Alafasy_64kbps/086002.mp3"
    },
    {
      "number": 3,
      "arabic": "النَّجْمُ الثَّاقِبُ",
      "bm": "Bintang yang terang.",
      "en": "The bright star.",
      "audio": "https://everyayah.com/data/Alafasy_64kbps/086003.mp3"
    },
    {
      "number": 4,
      "arabic": "إِنْ كُلُّ نَفْسٍ لَمَّا عَلَيْهَا حَافِظٌ",
      "bm": "Sudah pasti, tiap tiap orang telah dijaga rapi.",
      "en": "Absolutely, everyone is well guarded.",
      "audio": "https://everyayah.com/data/Alafasy_64kbps/086004.mp3"
    },
    {
      "number": 5,
      "arabic": "فَلْيَنْظُرِ الْإِنْسَانُ مِمَّ خُلِقَ",
      "bm": "hendaklah manusia memperhatikan tentang penciptaannya.",
      "en": "Let the human reflect on his creation.",
      "audio": "https://everyayah.com/data/Alafasy_64kbps/086005.mp3"
    },
    {
      "number": 6,
      "arabic": "خُلِقَ مِنْ مَاءٍ دَافِقٍ",
      "bm": "Dia telah diciptakan dari cecair yang terpancut.",
      "en": "He was created from ejected liquid.",
      "audio": "https://everyayah.com/data/Alafasy_64kbps/086006.mp3"
    },
    {
      "number": 7,
      "arabic": "يَخْرُجُ مِنْ بَيْنِ الصُّلْبِ وَالتَّرَائِبِ",
      "bm": "Diantara tulang belakang dan visera.",
      "en": "From between the spine and the viscera.",
      "audio": "https://everyayah.com/data/Alafasy_64kbps/086007.mp3"
    },
    {
      "number": 8,
      "arabic": "إِنَّهُ عَلَىٰ رَجْعِهِ لَقَادِرٌ",
      "bm": "Tentu sekali Dia berupaya untuk membangkitkannya.",
      "en": "He is certainly able to resurrect him.",
      "audio": "https://everyayah.com/data/Alafasy_64kbps/086008.mp3"
    },
    {
      "number": 9,
      "arabic": "يَوْمَ تُبْلَى السَّرَائِرُ",
      "bm": "Dihari yang semua rahsia rahsia dapat diketahui.",
      "en": "The day all secrets become known.",
      "audio": "https://everyayah.com/data/Alafasy_64kbps/086009.mp3"
    },
    {
      "number": 10,
      "arabic": "فَمَا لَهُ مِنْ قُوَّةٍ وَلَا نَاصِرٍ",
      "bm": "Dia tidak akan mempunyai kuasa, ataupun seorang penolong.",
      "en": "He will have no power, nor a helper.",
      "audio": "https://everyayah.com/data/Alafasy_64kbps/086010.mp3"
    },
    {
      "number": 11,
      "arabic": "وَالسَّمَاءِ ذَاتِ الرَّجْعِ",
      "bm": "Dari langit yang memulangkan (air).",
      "en": "By the sky that returns (the water).",
      "audio": "https://everyayah.com/data/Alafasy_64kbps/086011.mp3"
    },
    {
      "number": 12,
      "arabic": "وَالْأَرْضِ ذَاتِ الصَّدْعِ",
      "bm": "Demi bumi yang terbelah (untuk menumbuhkan tumbuh tumbuhan).",
      "en": "By the earth that cracks (to grow plants).",
      "audio": "https://everyayah.com/data/Alafasy_64kbps/086012.mp3"
    },
    {
      "number": 13,
      "arabic": "إِنَّهُ لَقَوْلٌ فَصْلٌ",
      "bm": "Ini adalah pengisahan yang serius.",
      "en": "This is a serious narration.",
      "audio": "https://everyayah.com/data/Alafasy_64kbps/086013.mp3"
    },
    {
      "number": 14,
      "arabic": "وَمَا هُوَ بِالْهَزْلِ",
      "bm": "Janganlah diambil ringan.",
      "en": "Not to be taken lightly.",
      "audio": "https://everyayah.com/data/Alafasy_64kbps/086014.mp3"
    },
    {
      "number": 15,
      "arabic": "إِنَّهُمْ يَكِيدُونَ كَيْدًا",
      "bm": "Mereka berkomplot dan merancang.",
      "en": "They plot and scheme.",
      "audio": "https://everyayah.com/data/Alafasy_64kbps/086015.mp3"
    },
    {
      "number": 16,
      "arabic": "وَأَكِيدُ كَيْدًا",
      "bm": "Begitu juga dengan Aku.",
      "en": "But so do I.",
      "audio": "https://everyayah.com/data/Alafasy_64kbps/086016.mp3"
    },
    {
      "number": 17,
      "arabic": "فَمَهِّلِ الْكَافِرِينَ أَمْهِلْهُمْ رُوَيْدًا",
      "bm": "Biarkanlah pengingkar pengingkar berihat buat seketika.",
      "en": "Just respite the disbelievers a short respite.",
      "audio": "https://everyayah.com/data/Alafasy_64kbps/086017.mp3"
    }
  ]
}