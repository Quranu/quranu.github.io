{
  "surahNumber": 102,
  "name": {
    "ar": "سورة الـتكاثر",
    "bm": "Mengumpulkan",
    "en": "Hoarding"
  },
  "totalAyahs": 8,
  "ayahs": [
    {
      "number": 0,
      "arabic": "بِسْمِ اللَّهِ الرَّحْمَٰنِ الرَّحِيمِ",
      "bm": "Dengan Nama Allah yang Maha Pengasih lagi Maha Penyayang.",
      "en": "In the name of God, Most Gracious, Most Merciful",
      "audio": "https://everyayah.com/data/Alafasy_64kbps/102000.mp3"
    },
    {
      "number": 1,
      "arabic": "أَلهاكُمُ التَّكاثُرُ",
      "bm": "Kamu menjadi sibuk dengan mengumpul.",
      "en": "You remain preoccupied with hoarding.",
      "audio": "https://everyayah.com/data/Alafasy_64kbps/102001.mp3"
    },
    {
      "number": 2,
      "arabic": "حَتَّىٰ زُرْتُمُ الْمَقَابِرَ",
      "bm": "Sehinggakan kamu masuk kedalam kubur kubur.",
      "en": "Until you go to the graves.",
      "audio": "https://everyayah.com/data/Alafasy_64kbps/102002.mp3"
    },
    {
      "number": 3,
      "arabic": "كَلَّا سَوْفَ تَعْلَمُونَ",
      "bm": "Sesungguhnya, kamu akan mendapat tahu.",
      "en": "Indeed, you will find out.",
      "audio": "https://everyayah.com/data/Alafasy_64kbps/102003.mp3"
    },
    {
      "number": 4,
      "arabic": "ثُمَّ كَلَّا سَوْفَ تَعْلَمُونَ",
      "bm": "Sudah pasti, kamu akan mendapat tahu.",
      "en": "Most assuredly, you will find out.",
      "audio": "https://everyayah.com/data/Alafasy_64kbps/102004.mp3"
    },
    {
      "number": 5,
      "arabic": "كَلَّا لَوْ تَعْلَمُونَ عِلْمَ الْيَقِينِ",
      "bm": "Jika hanya kamu dapat mengetahui dengan yakin.",
      "en": "If only you could find out for certain.",
      "audio": "https://everyayah.com/data/Alafasy_64kbps/102005.mp3"
    },
    {
      "number": 6,
      "arabic": "لَتَرَوُنَّ الْجَحِيمَ",
      "bm": "Tentunya kamu akan dapat bayangkan Neraka.",
      "en": "You would envision Hell.",
      "audio": "https://everyayah.com/data/Alafasy_64kbps/102006.mp3"
    },
    {
      "number": 7,
      "arabic": "ثُمَّ لَتَرَوُنَّهَا عَيْنَ الْيَقِينِ",
      "bm": "Lalu kamu akan dapat melihatnya dengan mata yang penuh keyakinan.",
      "en": "Then you would see it with the eye of certainty.",
      "audio": "https://everyayah.com/data/Alafasy_64kbps/102007.mp3"
    },
    {
      "number": 8,
      "arabic": "ثُمَّ لَتُسْأَلُنَّ يَوْمَئِذٍ عَنِ النَّعِيمِ",
      "bm": "Maka kamu akan disoal, pada hari itu, tentang rahmat yang telah kamu nikmati.",
      "en": "Then you will be questioned, on that day, about the blessings you had enjoyed.",
      "audio": "https://everyayah.com/data/Alafasy_64kbps/102008.mp3"
    }
  ]
}