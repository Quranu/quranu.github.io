{
  "surahNumber": 80,
  "name": {
    "ar": "سورة عبس",
    "bm": "Berkerut Dahi",
    "en": "He Frowned"
  },
  "totalAyahs": 42,
  "ayahs": [
    {
      "number": 0,
      "arabic": "بِسْمِ اللَّهِ الرَّحْمَٰنِ الرَّحِيمِ",
      "bm": "Dengan Nama Allah yang Maha Pengasih lagi Maha Penyayang.",
      "en": "In the name of God, Most Gracious, Most Merciful",
      "audio": "https://everyayah.com/data/Alafasy_64kbps/080000.mp3"
    },
    {
      "number": 1,
      "arabic": "عَبَسَ وَتَوَلّىٰ",
      "bm": "Dia (Muhammad) mengerutkan dahinya dan berpaling.",
      "en": "He (Muhammad) frowned and turned away.",
      "audio": "https://everyayah.com/data/Alafasy_64kbps/080001.mp3"
    },
    {
      "number": 2,
      "arabic": "أَنْ جَاءَهُ الْأَعْمَىٰ",
      "bm": "Apabila seorang lelaki buta datang kepadanya.",
      "en": "When the blind man came to him.",
      "audio": "https://everyayah.com/data/Alafasy_64kbps/080002.mp3"
    },
    {
      "number": 3,
      "arabic": "وَمَا يُدْرِيكَ لَعَلَّهُ يَزَّكَّىٰ",
      "bm": "Bagaimanakah kamu tahu? Mungkin dia dapat menyucikan dirinya sendiri.",
      "en": "How do you know? He may purify himself.",
      "audio": "https://everyayah.com/data/Alafasy_64kbps/080003.mp3"
    },
    {
      "number": 4,
      "arabic": "أَوْ يَذَّكَّرُ فَتَنْفَعَهُ الذِّكْرَىٰ",
      "bm": "Ataupun mungkin dia dapat merenungkan, dan memanfaatkan dari mesej itu.",
      "en": "Or he may take heed, and benefit from the message.",
      "audio": "https://everyayah.com/data/Alafasy_64kbps/080004.mp3"
    },
    {
      "number": 5,
      "arabic": "أَمَّا مَنِ اسْتَغْنَىٰ",
      "bm": "Bagi seorang lelaki yang kaya.",
      "en": "As for the rich man.",
      "audio": "https://everyayah.com/data/Alafasy_64kbps/080005.mp3"
    },
    {
      "number": 6,
      "arabic": "فَأَنْتَ لَهُ تَصَدَّىٰ",
      "bm": "Kau memberikannya perhatianmu.",
      "en": "You gave him your attention.",
      "audio": "https://everyayah.com/data/Alafasy_64kbps/080006.mp3"
    },
    {
      "number": 7,
      "arabic": "وَمَا عَلَيْكَ أَلَّا يَزَّكَّىٰ",
      "bm": "Walaupun kau tidak dapat memastikan keselamatannya.",
      "en": "Even though you could not guarantee his salvation.",
      "audio": "https://everyayah.com/data/Alafasy_64kbps/080007.mp3"
    },
    {
      "number": 8,
      "arabic": "وَأَمَّا مَنْ جَاءَكَ يَسْعَىٰ",
      "bm": "Seorang yang datang kepadamu dengan penuh minat.",
      "en": "The one who came to you eagerly.",
      "audio": "https://everyayah.com/data/Alafasy_64kbps/080008.mp3"
    },
    {
      "number": 9,
      "arabic": "وَهُوَ يَخْشَىٰ",
      "bm": "Dan bersunguh sungguh menghormatkan.",
      "en": "And is really reverent.",
      "audio": "https://everyayah.com/data/Alafasy_64kbps/080009.mp3"
    },
    {
      "number": 10,
      "arabic": "فَأَنْتَ عَنْهُ تَلَهَّىٰ",
      "bm": "Kau tidak memperdulikannya.",
      "en": "You ignored him.",
      "audio": "https://everyayah.com/data/Alafasy_64kbps/080010.mp3"
    },
    {
      "number": 11,
      "arabic": "كَلَّا إِنَّهَا تَذْكِرَةٌ",
      "bm": "Sesungguhnya, ini adalah satu Peringatan.",
      "en": "Indeed, this is a reminder.",
      "audio": "https://everyayah.com/data/Alafasy_64kbps/080011.mp3"
    },
    {
      "number": 12,
      "arabic": "فَمَنْ شَاءَ ذَكَرَهُ",
      "bm": "Sesiapa saja kehendaki bolehlah mengambil pelajaran.",
      "en": "Whoever wills shall take heed.",
      "audio": "https://everyayah.com/data/Alafasy_64kbps/080012.mp3"
    },
    {
      "number": 13,
      "arabic": "فِي صُحُفٍ مُكَرَّمَةٍ",
      "bm": "Didalam kitab kitab yang mulia.",
      "en": "In honorable scriptures.",
      "audio": "https://everyayah.com/data/Alafasy_64kbps/080013.mp3"
    },
    {
      "number": 14,
      "arabic": "مَرْفُوعَةٍ مُطَهَّرَةٍ",
      "bm": "Tinggi dan suci.",
      "en": "Exalted and pure.",
      "audio": "https://everyayah.com/data/Alafasy_64kbps/080014.mp3"
    },
    {
      "number": 15,
      "arabic": "بِأَيْدِي سَفَرَةٍ",
      "bm": "(Tertulis) oleh tangan tangan para rasul.",
      "en": "(Written) by the hands of messengers.",
      "audio": "https://everyayah.com/data/Alafasy_64kbps/080015.mp3"
    },
    {
      "number": 16,
      "arabic": "كِرَامٍ بَرَرَةٍ",
      "bm": "Yang amat mulia dan orang orang yang salih.",
      "en": "Who are honorable and righteous.",
      "audio": "https://everyayah.com/data/Alafasy_64kbps/080016.mp3"
    },
    {
      "number": 17,
      "arabic": "قُتِلَ الْإِنْسَانُ مَا أَكْفَرَهُ",
      "bm": "Malang sungguh bagi manusia ; dia amatlah tidak bersyukur!",
      "en": "Woe to the human being; he is so unappreciative!",
      "audio": "https://everyayah.com/data/Alafasy_64kbps/080017.mp3"
    },
    {
      "number": 18,
      "arabic": "مِنْ أَيِّ شَيْءٍ خَلَقَهُ",
      "bm": "Dari apakah Dia menciptakannya?",
      "en": "What did He create him from?",
      "audio": "https://everyayah.com/data/Alafasy_64kbps/080018.mp3"
    },
    {
      "number": 19,
      "arabic": "مِنْ نُطْفَةٍ خَلَقَهُ فَقَدَّرَهُ",
      "bm": "Dari setitik yang halus, Dia menciptakannya dan membentuknya.",
      "en": "From a tiny drop, He creates him and designs him.",
      "audio": "https://everyayah.com/data/Alafasy_64kbps/080019.mp3"
    },
    {
      "number": 20,
      "arabic": "ثُمَّ السَّبِيلَ يَسَّرَهُ",
      "bm": "Lalu Dia menunjukkan jalan untuknya.",
      "en": "Then He points out the path for him.",
      "audio": "https://everyayah.com/data/Alafasy_64kbps/080020.mp3"
    },
    {
      "number": 21,
      "arabic": "ثُمَّ أَمَاتَهُ فَأَقْبَرَهُ",
      "bm": "Lalu Dia mematikannya, dan dimasukkan kedalam kubur.",
      "en": "Then He puts him to death, and into the grave.",
      "audio": "https://everyayah.com/data/Alafasy_64kbps/080021.mp3"
    },
    {
      "number": 22,
      "arabic": "ثُمَّ إِذَا شَاءَ أَنْشَرَهُ",
      "bm": "Apabila Dia kehendaki, Dia membangkitkannya.",
      "en": "When He wills, He resurrects him.",
      "audio": "https://everyayah.com/data/Alafasy_64kbps/080022.mp3"
    },
    {
      "number": 23,
      "arabic": "كَلَّا لَمَّا يَقْضِ مَا أَمَرَهُ",
      "bm": "Dia mestilah mendukung perintah perintahNya.",
      "en": "He shall uphold His commandments.",
      "audio": "https://everyayah.com/data/Alafasy_64kbps/080023.mp3"
    },
    {
      "number": 24,
      "arabic": "فَلْيَنْظُرِ الْإِنْسَانُ إِلَىٰ طَعَامِهِ",
      "bm": "Biarkanlah manusia membuat pertimbangan tentang makanannya!",
      "en": "Let the human consider his food!",
      "audio": "https://everyayah.com/data/Alafasy_64kbps/080024.mp3"
    },
    {
      "number": 25,
      "arabic": "أَنَّا صَبَبْنَا الْمَاءَ صَبًّا",
      "bm": "Kami menyiramkan air dengan secukupnya.",
      "en": "We pour the water generously.",
      "audio": "https://everyayah.com/data/Alafasy_64kbps/080025.mp3"
    },
    {
      "number": 26,
      "arabic": "ثُمَّ شَقَقْنَا الْأَرْضَ شَقًّا",
      "bm": "Lalu kami merekahkan tanah terbuka.",
      "en": "Then we split the soil open.",
      "audio": "https://everyayah.com/data/Alafasy_64kbps/080026.mp3"
    },
    {
      "number": 27,
      "arabic": "فَأَنْبَتْنَا فِيهَا حَبًّا",
      "bm": "Kami tumbuhkan didalamnya biji bijian.",
      "en": "We grow in it grains.",
      "audio": "https://everyayah.com/data/Alafasy_64kbps/080027.mp3"
    },
    {
      "number": 28,
      "arabic": "وَعِنَبًا وَقَضْبًا",
      "bm": "Anggur anggur dan padang rumput ternak.",
      "en": "Grapes and pasture.",
      "audio": "https://everyayah.com/data/Alafasy_64kbps/080028.mp3"
    },
    {
      "number": 29,
      "arabic": "وَزَيْتُونًا وَنَخْلًا",
      "bm": "Pokok pokok zaitun dan pokok pokok palma.",
      "en": "Olives and palms.",
      "audio": "https://everyayah.com/data/Alafasy_64kbps/080029.mp3"
    },
    {
      "number": 30,
      "arabic": "وَحَدَائِقَ غُلْبًا",
      "bm": "Kebun kebun yang berbagai macam.",
      "en": "A variety of orchards.",
      "audio": "https://everyayah.com/data/Alafasy_64kbps/080030.mp3"
    },
    {
      "number": 31,
      "arabic": "وَفَاكِهَةً وَأَبًّا",
      "bm": "Buah buahan dan sayur sayuran.",
      "en": "Fruits and vegetables.",
      "audio": "https://everyayah.com/data/Alafasy_64kbps/080031.mp3"
    },
    {
      "number": 32,
      "arabic": "مَتَاعًا لَكُمْ وَلِأَنْعَامِكُمْ",
      "bm": "Untuk memberikan bantuan kehidupan kepada kamu dan binatang binatang kamu.",
      "en": "To provide life support for you and your animals.",
      "audio": "https://everyayah.com/data/Alafasy_64kbps/080032.mp3"
    },
    {
      "number": 33,
      "arabic": "فَإِذَا جَاءَتِ الصَّاخَّةُ",
      "bm": "Lalu, apabila tiupan berlaku.",
      "en": "Then, when the blow comes to pass.",
      "audio": "https://everyayah.com/data/Alafasy_64kbps/080033.mp3"
    },
    {
      "number": 34,
      "arabic": "يَوْمَ يَفِرُّ الْمَرْءُ مِنْ أَخِيهِ",
      "bm": "Itulah harinya apabila seorang melarikan diri dari saudara lelakinya.",
      "en": "That is the day when one flees from his brother.",
      "audio": "https://everyayah.com/data/Alafasy_64kbps/080034.mp3"
    },
    {
      "number": 35,
      "arabic": "وَأُمِّهِ وَأَبِيهِ",
      "bm": "Dari ibu dan bapanya.",
      "en": "From his mother and father.",
      "audio": "https://everyayah.com/data/Alafasy_64kbps/080035.mp3"
    },
    {
      "number": 36,
      "arabic": "وَصَاحِبَتِهِ وَبَنِيهِ",
      "bm": "Dari pasangannya dan anak anaknya.",
      "en": "From his spouse and children.",
      "audio": "https://everyayah.com/data/Alafasy_64kbps/080036.mp3"
    },
    {
      "number": 37,
      "arabic": "لِكُلِّ امْرِئٍ مِنْهُمْ يَوْمَئِذٍ شَأْنٌ يُغْنِيهِ",
      "bm": "Tiap tiap dari mereka, pada hari itu, bimbangkan tentang destininya sendiri.",
      "en": "Each one of them, on that day, worries about his own destiny.",
      "audio": "https://everyayah.com/data/Alafasy_64kbps/080037.mp3"
    },
    {
      "number": 38,
      "arabic": "وُجُوهٌ يَوْمَئِذٍ مُسْفِرَةٌ",
      "bm": "Ada wajah wajah pada hari itu akan bergembira.",
      "en": "Some faces on that day will be happy.",
      "audio": "https://everyayah.com/data/Alafasy_64kbps/080038.mp3"
    },
    {
      "number": 39,
      "arabic": "ضَاحِكَةٌ مُسْتَبْشِرَةٌ",
      "bm": "Ketawa dan kegirangan.",
      "en": "Laughing and joyful.",
      "audio": "https://everyayah.com/data/Alafasy_64kbps/080039.mp3"
    },
    {
      "number": 40,
      "arabic": "وَوُجُوهٌ يَوْمَئِذٍ عَلَيْهَا غَبَرَةٌ",
      "bm": "Wajah wajah yang lainnya, pada hari itu, akan ditutupi dengan derita.",
      "en": "Other faces, on that day, will be covered with misery.",
      "audio": "https://everyayah.com/data/Alafasy_64kbps/080040.mp3"
    },
    {
      "number": 41,
      "arabic": "تَرْهَقُهَا قَتَرَةٌ",
      "bm": "Diselubungi dengan penyesalan.",
      "en": "Overwhelmed by remorse.",
      "audio": "https://everyayah.com/data/Alafasy_64kbps/080041.mp3"
    },
    {
      "number": 42,
      "arabic": "أُولَٰئِكَ هُمُ الْكَفَرَةُ الْفَجَرَةُ",
      "bm": "Mereka inilah pengingkar pengingkar yang zalim.",
      "en": "These are the wicked disbelievers.",
      "audio": "https://everyayah.com/data/Alafasy_64kbps/080042.mp3"
    }
  ]
}