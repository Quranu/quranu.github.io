{
  "surahNumber": 101,
  "name": {
    "ar": "سورة القارعة",
    "bm": "Memeranjatkan",
    "en": "The Shocker"
  },
  "totalAyahs": 11,
  "ayahs": [
    {
      "number": 0,
      "arabic": "بِسْمِ اللَّهِ الرَّحْمَٰنِ الرَّحِيمِ",
      "bm": "Dengan Nama Allah yang Maha Pengasih lagi Maha Penyayang.",
      "en": "In the name of God, Most Gracious, Most Merciful",
      "audio": "https://everyayah.com/data/Alafasy_64kbps/101000.mp3"
    },
    {
      "number": 1,
      "arabic": "القارِعَةُ",
      "bm": "Yang memeranjatkan.",
      "en": "The Shocker.",
      "audio": "https://everyayah.com/data/Alafasy_64kbps/101001.mp3"
    },
    {
      "number": 2,
      "arabic": "مَا الْقَارِعَةُ",
      "bm": "Apakah yang memeranjatkan!",
      "en": "What a shocker!",
      "audio": "https://everyayah.com/data/Alafasy_64kbps/101002.mp3"
    },
    {
      "number": 3,
      "arabic": "وَمَا أَدْرَٮکَ مَا الْقَارِعَةُ",
      "bm": "Adakah kamu mempunyai idea apakah yang memeranjatkan itu?",
      "en": "Do you have any idea what the Shocker is?",
      "audio": "https://everyayah.com/data/Alafasy_64kbps/101003.mp3"
    },
    {
      "number": 4,
      "arabic": "يَوْمَ يَكُونُ النَّاسُ كَالْفَرَاشِ الْمَبْثُوثِ",
      "bm": "Itulah harinya apabila manusia keluar seperti kumpulan kumpulan kupu kupu.",
      "en": "That is the day when the people come out like swarms of butterflies.",
      "audio": "https://everyayah.com/data/Alafasy_64kbps/101004.mp3"
    },
    {
      "number": 5,
      "arabic": "وَتَكُونُ الْجِبَالُ كَالْعِهْنِ الْمَنْفُوشِ",
      "bm": "Gunung gunung akan menjadi seperti benang bulu bulu yang ringan.",
      "en": "The mountains will be like fluffy wool.",
      "audio": "https://everyayah.com/data/Alafasy_64kbps/101005.mp3"
    },
    {
      "number": 6,
      "arabic": "فَأَمَّا مَنْ ثَقُلَتْ مَوَازِينُهُ",
      "bm": "Baginya yang pertimbangannya berat",
      "en": "As for him whose weights are heavy.",
      "audio": "https://everyayah.com/data/Alafasy_64kbps/101006.mp3"
    },
    {
      "number": 7,
      "arabic": "فَهُوَ فِي عِيشَةٍ رَاضِيَةٍ",
      "bm": "Dia akan menjalani penghidupan yang (kekal) bahagia",
      "en": "He will lead a happy (eternal) life.",
      "audio": "https://everyayah.com/data/Alafasy_64kbps/101007.mp3"
    },
    {
      "number": 8,
      "arabic": "وَأَمَّا مَنْ خَفَّتْ مَوَازِينُهُ",
      "bm": "Baginya yang pertimbangannya ringan.",
      "en": "As for him whose weights are light.",
      "audio": "https://everyayah.com/data/Alafasy_64kbps/101008.mp3"
    },
    {
      "number": 9,
      "arabic": "فَأُمُّهُ هَاوِيَةٌ",
      "bm": "Destininya adalah yang paling bawah.",
      "en": "His destiny is lowly.",
      "audio": "https://everyayah.com/data/Alafasy_64kbps/101009.mp3"
    },
    {
      "number": 10,
      "arabic": "وَمَا أَدْرَٮکَ مَا هِيَهْ",
      "bm": "Tahukah kamu apakah ianya itu?",
      "en": "Do you know what it is?",
      "audio": "https://everyayah.com/data/Alafasy_64kbps/101010.mp3"
    },
    {
      "number": 11,
      "arabic": "نَارٌ حَامِيَةٌ",
      "bm": "Api Neraka yang menyala nyala.",
      "en": "The blazing Hellfire.",
      "audio": "https://everyayah.com/data/Alafasy_64kbps/101011.mp3"
    }
  ]
}